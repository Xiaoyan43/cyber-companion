DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Volcano Engine / Doubao cloud TTS V3 (optional; set config/tts.json default_provider to doubao).
# API Key from 语音技术控制台 → API Key 管理 (NOT Ark platform ark- keys).
DOUBAO_TTS_API_KEY=
# 灿灿 2.0 (big-model V3). Legacy BV700_streaming needs old v1 API + APPID.
DOUBAO_TTS_VOICE_TYPE=zh_female_cancan_uranus_bigtts
# seed-tts-2.0           → standard (stable, no voice instruction [#...] support)
# seed-tts-2.0-expressive → expressive (P6-E: supports [#语气指令] in text; has generation variance)
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
# Legacy alias: DOUBAO_TTS_ACCESS_TOKEN is accepted if API_KEY is empty.

# Volcano Engine / Doubao cloud ASR (optional; set config/stt.json default_provider to doubao).
# API Key from 语音技术控制台 → API Key 管理 (same console family as TTS; NOT legacy AppID/Token).
DOUBAO_API_KEY=
# Flash ASR resource ID (default volc.bigasr.auc_turbo per official docs).
DOUBAO_ASR_RESOURCE_ID=volc.bigasr.auc_turbo

# Doubao Dialog S2S (realtime mode only — 火山控制台 → 端到端实时语音大模型 → App ID + Access Token)
DOUBAO_RT_APP_ID=
DOUBAO_RT_ACCESS_TOKEN=
# O2.0 S2S uses *_jupiter_bigtts (not *_uranus_bigtts — that's HTTP TTS 2.0 only)
# Optional: DOUBAO_RT_SPEAKER=zh_female_vv_jupiter_bigtts  DOUBAO_RT_MODEL=1.2.1.1
# RTC S2S model line: o (O2.0 default) or sc (SC2.0 + character_manifest) — see docs/V2_RTC_SC2_VERIFY_SPEC.md
# DOUBAO_RT_SERIES=o
# SC2.0 spike: DOUBAO_RT_SERIES=sc  DOUBAO_RT_MODEL=2.2.0.0  DOUBAO_RT_SPEAKER=<saturn_…>
# O2.0 singing needs dialog.extra.enable_music (default on; set false to disable)
# DOUBAO_RT_ENABLE_MUSIC=true
# DOUBAO_RT_AUDIO_FORMAT=pcm_s16le  (default; Pipecat needs 16-bit — not float ``pcm``)

# Volcengine RTC AIGC (Stage 2 demo — rtc-aigc-demo adjacent clone; see docs/RTC_DEMO_SETUP.md)
VOLC_RTC_APP_ID=
VOLC_RTC_APP_KEY=
# IAM AK/SK — signs StartVoiceChat OpenAPI (https://console.volcengine.com/iam/keymanage/)
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=
# Stable RTC user id for Viking MemoryConfig filter (default boxi_user)
VOLC_RTC_DEFAULT_USER_ID=boxi_user
# Pure E2E ASR twopass (default off): enabling can finalize one utterance twice → double reply/audio
# VOLC_RTC_ENABLE_ASR_TWOPASS=0
# Viking long-term memory for pure E2E RTC — see docs/V2_RTC_VIKING_MEMORY_SPEC.md
# API Key from Viking 记忆库控制台（敏感；只放 .env，勿提交）
VIKING_MEMORY_API_KEY=
VIKING_MEMORY_COLLECTION=
# VIKING_MEMORY_PROJECT=default
# VIKING_MEMORY_HOST=https://api-knowledgebase.mlp.cn-beijing.volces.com
# VIKING_MEMORY_LIMIT=3
# VIKING_MEMORY_TRANSITION_WORDS=根据你之前的记录：
# VIKING_MEMORY_ASSISTANT_ID=
# VIKING_MEMORY_TYPES=order_event,profile_event

CYBER_COMPANION_PROVIDER_MODE=mock
# Empty = use config/stt.json (default faster_whisper). Set to "mock" for placeholder STT.
CYBER_COMPANION_STT_MODE=
# Empty = use config/tts.json (default mac_say). Set to "mock" for silent offline TTS.
CYBER_COMPANION_TTS_MODE=
CYBER_COMPANION_CONFIG_DIR=./config
CYBER_COMPANION_DATA_DIR=./data
CYBER_COMPANION_API_HOST=127.0.0.1
CYBER_COMPANION_API_PORT=8000

# Soul LLM (RTC Stage 1 — OpenAI-compatible endpoint for AIGC custom LLM)
SOUL_LLM_HOST=127.0.0.1
SOUL_LLM_PORT=8100
SOUL_LLM_API_KEY=
# Hybrid RTC (Stage 2c): public soul URL incl. path, e.g. https://xxxx.trycloudflare.com/v1/chat/completions
SOUL_LLM_PUBLIC_URL=
# Tunnel for Stage 2b: cloudflared (default) or ngrok
SOUL_TUNNEL_PROVIDER=cloudflared
# Comma-separated extra dev frontend origins (defaults already include 5173/5174 on localhost).
CYBER_COMPANION_CORS_ORIGINS=
