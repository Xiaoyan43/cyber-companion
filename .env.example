DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Volcano Engine / Doubao cloud TTS V3 (optional; set config/tts.json default_provider to doubao).
# API Key from 语音技术控制台 → API Key 管理 (NOT Ark platform ark- keys).
DOUBAO_TTS_API_KEY=
# 灿灿 2.0 (big-model V3). Legacy BV700_streaming needs old v1 API + APPID.
DOUBAO_TTS_VOICE_TYPE=zh_female_cancan_uranus_bigtts
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
# Legacy alias: DOUBAO_TTS_ACCESS_TOKEN is accepted if API_KEY is empty.

# Volcano Engine / Doubao cloud ASR (optional; set config/stt.json default_provider to doubao).
# API Key from 语音技术控制台 → API Key 管理 (same console family as TTS; NOT legacy AppID/Token).
DOUBAO_API_KEY=
# Flash ASR resource ID (default volc.bigasr.auc_turbo per official docs).
DOUBAO_ASR_RESOURCE_ID=volc.bigasr.auc_turbo

CYBER_COMPANION_PROVIDER_MODE=mock
# Empty = use config/stt.json (default faster_whisper). Set to "mock" for placeholder STT.
CYBER_COMPANION_STT_MODE=
# Empty = use config/tts.json (default mac_say). Set to "mock" for silent offline TTS.
CYBER_COMPANION_TTS_MODE=
CYBER_COMPANION_CONFIG_DIR=./config
CYBER_COMPANION_DATA_DIR=./data
CYBER_COMPANION_API_HOST=127.0.0.1
CYBER_COMPANION_API_PORT=8000
# Comma-separated extra dev frontend origins (defaults already include 5173/5174 on localhost).
CYBER_COMPANION_CORS_ORIGINS=
